{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": ["src/app/**/*.{ts,tsx}", "src/components/**/*.{ts,tsx}"],
	"project": ["src/**/*.{ts,tsx}"],
	"ignore": [],
	"ignoreDependencies": [
		"@swc/core",
		"autoprefixer",
		"globals",
		"shadcn",
		"tailwindcss-animate",
		"conventional-changelog-conventionalcommits"
	],
	"next": {
